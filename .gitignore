# ===== MEDIA FILES (large binaries — per episode) =====
episodes/**/assets/images/
episodes/**/assets/audio/
episodes/**/assets/music/
episodes/**/exports/

# Loose media files nếu lỡ để lung tung
*.mp4
*.mp3
*.wav
*.ogg
*.aac
*.flac
*.mov
*.avi
*.mkv
*.webm
*.png
*.jpg
*.jpeg
*.gif
